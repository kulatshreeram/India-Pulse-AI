# ═══════════════════════════════════════════════════════════════════════════════
# India Pulse AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git!
# ═══════════════════════════════════════════════════════════════════════════════

# ── AI APIs ────────────────────────────────────────────────────────────────────

# Google Gemini API Key (REQUIRED)
# Get yours free at: https://aistudio.google.com/app/apikey
# Used for: article summaries, AI chat, report generation
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional fallback)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── News Data ──────────────────────────────────────────────────────────────────

# GNews API Key (REQUIRED for live news)
# Free tier: 100 requests/day — get at: https://gnews.io/
# Without this, the app uses mock data
GNEWS_API_KEY=your_gnews_api_key_here

# ── App Config ─────────────────────────────────────────────────────────────────

# Your app's public URL (used for SEO metadata and OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API URL (used by Next.js API routes to proxy to FastAPI)
# In production, replace with your Railway/Render URL
BACKEND_URL=http://127.0.0.1:8000

# ── Authentication (Clerk — optional) ─────────────────────────────────────────
# Get keys at: https://clerk.com
# If not set, the app runs without authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register

# ── Database (optional — defaults to SQLite) ───────────────────────────────────
# For production, use PostgreSQL. Railway/Neon both provide free PostgreSQL.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Security (production only) ─────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins for the backend
# In development this defaults to localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
