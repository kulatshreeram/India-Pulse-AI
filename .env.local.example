# India Pulse AI Environment Variables
# Copy this file to .env.local and fill in your values

# ─── OpenAI (optional — graceful fallback if not set) ──────────────────────
OPENAI_API_KEY=

# ─── Clerk Authentication (optional) ───────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/map
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/map

# ─── NewsAPI (Phase 2 — real news data) ────────────────────────────────────
NEWS_API_KEY=
GNEWS_API_KEY=

# ─── App Config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=India Pulse AI
